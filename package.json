{
    "name": "@guilds/repo",
    "homepage": "https://guilds.js.org",
    "version": "0.0.0",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "docs/",
        "package/"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "format": "turbo run format",
        "lint": "turbo run lint"
    },
    "devDependencies": {
        "prettier": "^3.8.1",
        "turbo": "^2.8.16",
        "typescript": "^5.9.3"
    },
    "prettier": {
        "arrowParens": "always",
        "jsxSingleQuote": false,
        "printWidth": 85,
        "quoteProps": "as-needed",
        "semi": false,
        "singleQuote": false,
        "tabWidth": 4,
        "trailingComma": "es5",
        "useTabs": false
    },
    "packageManager": "pnpm@10.31.0",
    "engines": {
        "node": ">=20"
    }
}
